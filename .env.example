# Docker Compose PostgreSQL credentials.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="report_automation"

# Matches the Docker Compose service exposed on localhost:5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/report_automation"

# true: in-memory sample data, no database required
# false: Prisma + PostgreSQL persistence
DEMO_MODE="false"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
